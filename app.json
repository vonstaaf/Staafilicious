{
  "expo": {
    "name": "Workaholic",
    "slug": "staafilicious-frontend",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.staafilicious.workaholic",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Appen behöver tillgång till dina bilder för att du ska kunna ladda upp din företagslogotyp till dina Projekt."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.staafilicious.workaholic",
      "googleServicesFile": "google-services.json",
      "versionCode": 34,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tillåt Workaholic att använda dina bilder för att välja en logotyp till dina Projekt."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "84ce2dfb-06fd-4fe5-8703-cda97f21d310"
      }
    }
  }
}