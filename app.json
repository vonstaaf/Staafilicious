{
  "expo": {
    "name": "Workaholic",
    "slug": "staafilicious-frontend",
    "version": "1.0.79",
    "orientation": "portrait",
    "scheme": "workaholic",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.staafilicious.workaholic",
      "buildNumber": "29",
      "infoPlist": {
        "NSCameraUsageDescription": "Workaholic behöver tillgång till kameran för att kunna fota och dokumentera arbetet direkt i Projektet.",
        "NSPhotoLibraryUsageDescription": "Workaholic behöver tillgång till ditt bildbibliotek för att du ska kunna ladda upp sparade bilder till Projektet.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vonstaaf.staafiliciousfrontend",
      "versionCode": 80,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Workaholic behöver tillgång till ditt bildbibliotek för att du ska kunna ladda upp sparade bilder till Projektet.",
          "cameraPermission": "Workaholic behöver tillgång till kameran för att kunna fota och dokumentera arbetet direkt i Projektet."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Tillåt Workaholic att använda mikrofonen för röstinmatning i AI-arbetsordern.",
          "speechRecognitionPermission": "Tillåt Workaholic att använda taligenkänning för röstinmatning."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "supports16KPageSize": true,
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": true
              }
            }
          }
        }
      ]
    ],
    "extra": {
      "webUrl": "https://workaholic-web.vercel.app",
      "eas": {
        "projectId": "84ce2dfb-06fd-4fe5-8703-cda97f21d310"
      }
    },
    "owner": "vonstaaf"
  }
}